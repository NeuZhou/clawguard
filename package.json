{
  "name": "openclaw-watch",
  "version": "5.1.0",
  "description": "AI Agent Security & Observability Platform - 285+ threat patterns, OWASP Agentic AI mapping, SARIF output, zero native dependencies",
  "author": "Kang Zhou <neuzhou@outlook.com>",
  "license": "MIT",
  "keywords": [
    "openclaw", "security", "observability", "monitoring", "dashboard",
    "owasp", "llm-security", "prompt-injection", "mcp-security",
    "agent-security", "supply-chain", "sarif", "identity-protection",
    "ai-safety", "agentic-ai", "data-leakage", "skill-scanner"
  ],
  "homepage": "https://github.com/NeuZhou/openclaw-watch",
  "repository": {
    "type": "git",
    "url": "https://github.com/NeuZhou/openclaw-watch.git"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "bin": {
    "openclaw-watch": "./dist/src/cli.js",
    "openclaw-watch-scan": "./dist/src/skill-scanner.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "skill/",
    "rules.d/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "scan": "node --import tsx src/cli.ts scan",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
